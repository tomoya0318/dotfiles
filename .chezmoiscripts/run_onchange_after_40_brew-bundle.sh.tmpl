#!/bin/bash
# Brewfile が変わったら再実行:
# brewfile:   {{ include "Brewfile" | sha256sum }}
{{- if eq .chezmoi.os "darwin" }}
set -euo pipefail

BREWFILE="{{ .chezmoi.sourceDir }}/Brewfile"
if command -v brew >/dev/null 2>&1 && [ -f "$BREWFILE" ]; then
  echo ">>> brew bundle を実行 (CLI ツール・Cask をセットアップ)"
  brew bundle --file="$BREWFILE"
else
  echo ">>> brew or Brewfile が未準備、スキップ"
fi
{{- end }}
