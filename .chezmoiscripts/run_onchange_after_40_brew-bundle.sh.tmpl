#!/bin/bash
# Brewfile が変わったら再実行:
# brewfile:   {{ include "Brewfile" | sha256sum }}
{{- if eq .chezmoi.os "darwin" }}
set -euo pipefail

if command -v brew >/dev/null 2>&1 && [ -f "$HOME/Brewfile" ]; then
  echo ">>> brew bundle を実行 (Cask をセットアップ)"
  brew bundle --file="$HOME/Brewfile"
else
  echo ">>> brew or ~/Brewfile が未準備、スキップ"
fi
{{- end }}
