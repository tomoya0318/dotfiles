#!/bin/bash
# 研究サーバ (Linux) のみ: Nix が利用可能か検証する
# Nix 本体のインストールは root 作業が必要なため、事前に完了していることを前提とする
# 詳細は nix/README.md「研究サーバ セットアップ」を参照
{{- if eq .chezmoi.os "linux" }}
set -euo pipefail

if ! command -v nix >/dev/null 2>&1; then
  cat <<'EOF' >&2
>>> Nix がインストールされていません。
>>> 研究サーバの multi-user Nix セットアップは root 作業が必要です。
>>> nix/README.md の「研究サーバ セットアップ」を参照してください。
EOF
  exit 1
fi
echo ">>> Nix 導入済み: $(nix --version)"
{{- end }}
