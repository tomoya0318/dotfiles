#!/bin/bash
# 研究サーバ (Linux) のみ: home-manager switch を実行する
# home-research.nix の内容が変わったら再実行:
# research: {{ include "nix/home-research.nix" | sha256sum }}
{{- if eq .chezmoi.os "linux" }}
set -euo pipefail

if [ -e /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh ]; then
  . /nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh
fi

echo ">>> home-manager switch を適用 (flake: {{ .chezmoi.sourceDir }}/nix#research)"
nix run home-manager/release-24.11 -- switch \
  --flake "{{ .chezmoi.sourceDir }}/nix#research" \
  -b bak
{{- end }}
