// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
  },
  "vim": {
    "toggle_relative_line_numbers": true,
  },
  "disable_ai": true,
  "icon_theme": "Material Icon Theme",
  "multi_cursor_modifier": "cmd_or_ctrl",
  "buffer_font_weight": 400,
  "buffer_font_family": "Osaka",
  "buffer_font_fallbacks": ["Hiragino Sans"],
  "buffer_font_size": 16,
  "tab_size": 2,
  "buffer_font_features": {
    // font-feature = -dlig の反映
    "dlig": false,
  },
  // adjust-cell-height = 2 の代用（1.2倍程度が目安）
  "buffer_line_height": {
    "custom": 1.4,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "vim_mode": true,
  "ui_font_size": 18,
  "theme": {
    "mode": "system",
    "light": "One Dark",
    "dark": "One Dark",
  },
  "terminal": {
    "font_family": "JetBrains Mono",
    "font_size": 10,
    "line_height": {
      "custom": 1.2,
    },
    "font_features": {
      "dlig": false,
    },
  },
  "theme_overrides": {
    "Tokyo Night": {
      "text.muted": "#a9b1d6",
      "text": "#c0caf5",
    },
  },
}
