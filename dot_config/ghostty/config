# --- Appearance & Theme ---
# Zed と揃えた Tokyo Night (Night バリアント, 背景 #1a1b26)
theme = TokyoNight
# Zed 同様に文字は白寄りに上書き (デフォルト #c0caf5 は少し暗いため)
foreground = #ffffff

background-opacity = 1.0
background-blur-radius = 0

# --- Keybind ---
keybind = super+s=text:\x1bw\x0dd

# --- Font ---
font-family = "UDEV Gothic 35NF"
font-size = 14
font-feature = -dlig
font-thicken = true
font-thicken-strength = 128

# フォントスタイルをシンプルに固定
font-style-bold = false
font-style-italic = false
font-style-bold-italic = false

# 文字の間隔・描画調整
adjust-cell-width = 0%
adjust-cell-height = 10%
alpha-blending = linear

# --- Window & macOS UI ---
# 装飾の排除
# tabs: tab をタイトルバーに統合し独立した tab バー行を無くす（最もコンパクト）
macos-titlebar-style = tabs
macos-window-shadow = false

# 余白設定
window-padding-x = 10
window-padding-y = 10
window-padding-balance = true

# --- Cursor ---
cursor-style = block
cursor-style-blink = false
cursor-invert-fg-bg = true
cursor-opacity = 0.8

# --- Input & Mouse ---
# NeovimでのOptionキー操作を有効化（必須級）
macos-option-as-alt = true
mouse-scroll-multiplier = 2
mouse-hide-while-typing = true

# --- Interaction ---
shell-integration-features = no-cursor
resize-overlay = never
