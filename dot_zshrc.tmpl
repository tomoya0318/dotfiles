# ==========================================
# 1. Path & Homebrew Initialization
# ==========================================
# Macの場合のHomebrew起動設定
{{- if eq .chezmoi.os "darwin" }}
eval "$(/opt/homebrew/bin/brew shellenv)"
{{- end }}

# $HOME を使うことで、ユーザー名が変わっても使い回せるように汎用化
export PATH="$PATH:$HOME/.local/bin"

# Mac/Linuxの環境差異を吸収するための変数 (OS共通)
HOMEBREW_DIR=${HOMEBREW_PREFIX:-$(brew --prefix 2>/dev/null)}

# ==========================================
# 2. Android & Java Environment
# ==========================================
# 開発用Macだけで読み込む限定設定 (ホスト名で指定)
{{- if eq .chezmoi.hostname "MacBook-Pro-2" }}
export JAVA_HOME=/Library/Java/JavaVirtualMachines/zulu-17.jdk/Contents/Home
export ANDROID_HOME=$HOME/Library/Android/sdk
export PATH=$PATH:$ANDROID_HOME/emulator
export PATH=$PATH:$ANDROID_HOME/platform-tools
{{- end }}

# ==========================================
# 3. History configuration (履歴設定)
# ==========================================
HISTFILE=$HOME/.zsh_history
HISTSIZE=1000000
SAVEHIST=1000000
setopt hist_ignore_dups
setopt hist_ignore_space
setopt share_history

# ==========================================
# 4. Completion configuration (補完設定)
# ==========================================
if [ -n "$HOMEBREW_DIR" ] && [ -d "${HOMEBREW_DIR}/share/zsh-completions" ]; then
    fpath=("${HOMEBREW_DIR}/share/zsh-completions" $fpath)
fi

autoload -Uz compinit
compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' format $'\e[2;37mCompleting %d\e[m'

# ==========================================
# 5. Tool Initialization (各種ツールの起動)
# ==========================================
eval "$(mise activate zsh)"
eval "$(direnv hook zsh)"
eval "$(starship init zsh)"

# ==========================================
# 6. Aliases
# ==========================================
alias dev="cd ~/dev"

# ==========================================
# 7. pnpm
# ==========================================
export PNPM_HOME="$HOME/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac

# ==========================================
# 8. Zsh Plugins (入力予測 & 構文ハイライト)
# ==========================================
if [ -n "$HOMEBREW_DIR" ]; then
    if [ -f "${HOMEBREW_DIR}/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ]; then
        source "${HOMEBREW_DIR}/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
    fi

    # ★必ず一番最後に読み込む
    if [ -f "${HOMEBREW_DIR}/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]; then
        source "${HOMEBREW_DIR}/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
    fi
fi

source ~/.orbstack/shell/init.zsh 2>/dev/null || :
