#!/bin/bash

# 【重要】Hookから実行されてもコマンドを解決できるようにPATHを通す
# Mac は Homebrew を先頭に、Linux は Nix user profile のみ
export PATH="{{ if eq .chezmoi.os "darwin" }}/opt/homebrew/bin:/usr/local/bin:{{ end }}$HOME/.nix-profile/bin:$PATH"

input=$(cat)

cwd=$(echo "$input" | jq -r '.cwd')
project=$(basename "$cwd")
hook_event=$(echo "$input" | jq -r '.hook_event_name')

case "$hook_event" in
  "Notification")
    message="許可待ち"
    ;;
  "Stop")
    message="タスク完了"
    ;;
  *)
    exit 0
    ;;
esac

# macOS デスクトップ通知 (terminal-notifier が入っていれば)
if command -v terminal-notifier >/dev/null 2>&1; then
  terminal-notifier -title "Claude Code" -subtitle "$project" -message "$message" -sound "Ping"
fi

# ntfy通知（スマホ） chezmoi.toml に [data.ntfy] が無ければ空になりスキップされる
NTFY_TOPIC="{{- if hasKey . "ntfy" }}{{ .ntfy.topic }}{{ end }}"
if [ -n "$NTFY_TOPIC" ]; then
  curl -s \
    -H "Title: Claude Code - $project" \
    -d "$message" \
    "https://ntfy.sh/$NTFY_TOPIC" > /dev/null 2>&1 &
fi
